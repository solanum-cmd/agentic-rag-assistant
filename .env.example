# ============================================================
# Agentic RAG Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# --- API Keys (set at least one) ----------------------------
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- Provider Selection -------------------------------------
# LLM_PROVIDER: "google" (default) or "openai"
LLM_PROVIDER=google

# EMBEDDING_PROVIDER: "huggingface" (default, free) or "openai"
EMBEDDING_PROVIDER=huggingface

# --- LLM Settings -------------------------------------------
# Leave blank to auto-select per provider
# Google default: gemini-2.5-flash | OpenAI default: gpt-4o-mini
LLM_MODEL_NAME=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# --- Embedding Settings -------------------------------------
# HuggingFace default: sentence-transformers/all-MiniLM-L6-v2
# OpenAI default: text-embedding-3-small
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- Text Splitting -----------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# --- Retrieval -----------------------------------------------
RETRIEVER_TOP_K=4
RELEVANCE_SCORE_THRESHOLD=0.3

# --- Memory --------------------------------------------------
MEMORY_MAX_TURNS=10

# --- ChromaDB ------------------------------------------------
CHROMA_COLLECTION_NAME=docmind_collection

# --- Logging -------------------------------------------------
LOG_LEVEL=INFO
